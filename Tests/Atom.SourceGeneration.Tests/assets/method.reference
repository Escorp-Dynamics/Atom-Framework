/// <summary>
/// Тестовый метод
/// </summary>
protected abstract int TestMethod(bool arg1, [NotNull] string? arg2);

/// <summary>
/// Тестовый метод
/// </summary>
protected internal virtual void TestMethod(bool arg1, [NotNull][Test] string? arg2) { }

/// <summary>
/// Тестовый метод
/// </summary>
protected internal virtual void TestMethod(bool arg1, [NotNull][Test] string? arg2) { }

/// <summary>
/// Тестовый метод
/// </summary>
bool TestMethod(bool arg1, string? arg2) => arg1 && !string.IsNullOrEmpty(arg2);

/// <summary>
/// Тестовый метод
/// </summary>
static void TestMethod(bool arg1, string? arg2)
{
    var test = arg1 && !string.IsNullOrEmpty(arg2);
    SomeMethod(test);
}

/// <summary>
/// Тестовый метод
/// </summary>
static void TestMethod<T>(bool arg1, string? arg2) where T : struct
{
    var test = arg1 && !string.IsNullOrEmpty(arg2);
    SomeMethod(test);
}
