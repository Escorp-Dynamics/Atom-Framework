/// <summary>
/// Тестовый метод
/// </summary>
/// <param name="arg1">Булев аргумент</param>
/// <param name="arg2">Строковый аргумент</param>
protected abstract System.Int32 TestMethod(System.Boolean arg1, [NotNull] System.String? arg2);

/// <summary>
/// Тестовый метод
/// </summary>
/// <param name="arg1">Булев аргумент</param>
/// <param name="arg2">Строковый аргумент</param>
protected internal virtual void TestMethod(System.Boolean arg1, [Test][Test] System.String? arg2) { }

/// <summary>
/// Тестовый метод
/// </summary>
/// <param name="arg1">Булев аргумент</param>
/// <param name="arg2">Строковый аргумент</param>
protected internal virtual void TestMethod(System.Boolean arg1, [Test][Test] System.String? arg2) { }

/// <summary>
/// Тестовый метод
/// </summary>
/// <param name="arg1">Булев аргумент</param>
/// <param name="arg2">Строковый аргумент</param>
System.Boolean TestMethod(System.Boolean arg1, System.String? arg2) => arg1 && !string.IsNullOrEmpty(arg2);

/// <summary>
/// Тестовый метод
/// </summary>
/// <param name="arg1">Булев аргумент</param>
/// <param name="arg2">Строковый аргумент</param>
static void TestMethod(System.Boolean arg1, System.String? arg2)
{
    var test = arg1 && !string.IsNullOrEmpty(arg2);
    SomeMethod(test);
}

/// <summary>
/// Тестовый метод
/// </summary>
/// <param name="arg1">Булев аргумент</param>
/// <param name="arg2">Строковый аргумент</param>
/// <typeparam name="T">Тестовый тип</typeparam>
static void TestMethod<T>(System.Boolean arg1, System.String? arg2) where T : struct
{
    var test = arg1 && !string.IsNullOrEmpty(arg2);
    SomeMethod(test);
}
