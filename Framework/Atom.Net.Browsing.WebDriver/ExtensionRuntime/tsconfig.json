{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "Bundler",
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "verbatimModuleSyntax": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": false
    },
    "include": [
        "./**/*.ts"
    ],
    "exclude": [
        "./node_modules",
        "./Packaging/**/*"
    ]
}