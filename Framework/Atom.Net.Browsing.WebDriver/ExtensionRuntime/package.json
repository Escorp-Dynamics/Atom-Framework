{
    "name": "atom-webdriver-extension-runtime",
    "private": true,
    "type": "module",
    "scripts": {
        "build:background": "node ./scripts/build-background-runtime.mjs",
        "build:content": "node ./scripts/build-content-runtime.mjs",
        "prepare:working-layout": "npm run build:background && npm run build:content && node ./scripts/sync-working-layout.mjs",
        "sign:firefox": "bash ./scripts/sign-firefox-package.sh",
        "test": "node --import tsx --test ./Tests/**/*.test.mjs",
        "typecheck": "tsc -p tsconfig.json --pretty false"
    },
    "devDependencies": {
        "crx3": "^1.1.3",
        "esbuild": "^0.25.3",
        "tsx": "^4.19.3",
        "typescript": "^5.8.2",
        "web-ext": "^8.8.0"
    }
}