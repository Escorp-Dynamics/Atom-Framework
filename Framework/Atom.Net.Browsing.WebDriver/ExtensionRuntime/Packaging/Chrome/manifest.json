{
    "manifest_version": 3,
    "name": "Atom WebDriver Connector",
    "version": "0.8.8",
    "description": "Мост между Atom.Net.Browsing.WebDriver и браузером для расширения мостового обмена",
    "permissions": [
        "tabs",
        "cookies",
        "proxy",
        "webNavigation",
        "webRequest",
        "storage",
        "scripting",
        "declarativeNetRequest"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.runtime.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start",
            "all_frames": false
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "config.json"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "minimum_chrome_version": "120"
}