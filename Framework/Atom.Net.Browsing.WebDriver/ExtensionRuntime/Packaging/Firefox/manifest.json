{
    "manifest_version": 2,
    "name": "Atom WebDriver Connector",
    "version": "0.8.8",
    "description": "Мост между Atom.Net.Browsing.WebDriver и браузером для расширения мостового обмена",
    "permissions": [
        "storage",
        "tabs",
        "cookies",
        "proxy",
        "webNavigation",
        "webRequest",
        "webRequestBlocking",
        "<all_urls>"
    ],
    "background": {
        "scripts": [
            "background.runtime.js"
        ],
        "persistent": true
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start",
            "all_frames": false
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "escorp-automation@escorp.local",
            "strict_min_version": "128.0"
        }
    }
}